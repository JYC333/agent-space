# Test environment template.
# scripts/start.sh --test copies this to $ASPACE_ROOT/test/.env on first run.
# Edit the copied file, not this template.

POSTGRES_MAJOR=18
POSTGRES_DB=agent_space_test
POSTGRES_USER=agent_space
POSTGRES_PASSWORD=agent_space_dev_password
# DATABASE_URL=postgresql://agent_space:agent_space_dev_password@localhost:5432/agent_space_test

# Server: client-facing API entrypoint inside the compose network.
SERVER_LOG_LEVEL=info
SERVER_REQUEST_TIMEOUT_MS=300000
# start.sh/migrate.sh generate the bundled-postgres owner DB URL and internal token.
# SERVER_DATABASE_URL=<auto-generated from POSTGRES_* by ops scripts>
# SERVER_INTERNAL_TOKEN=<auto-generated by ops scripts>
RUNTIME_TOOLS_ROOT=/aspace/runtime-tools

# Optional runtime tool npm install network config. Leave these unset when the
# server container can reach the npm registry directly. If a proxy runs on the
# host, use an address reachable from the container. The test compose file maps
# host.docker.internal to the Docker host.
# HTTPS_PROXY=http://host.docker.internal:7890
# HTTP_PROXY=http://host.docker.internal:7890
# ALL_PROXY=socks5h://host.docker.internal:7890
# NO_PROXY=localhost,127.0.0.1,postgres,server,frontend,deployer
# NPM_CONFIG_REGISTRY=https://registry.npmjs.org/

# Google OAuth test-stack defaults
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3100/api/v1/auth/google/callback
# FRONTEND_URL=http://localhost:3100

# Test-mode auth and defaults
SERVER_DEBUG=false
# SESSION_EXPIRE_DAYS=30
# DEFAULT_USER_ID=default_user
# INSTANCE_ADMIN_EMAIL=
# REFLECTOR_MODE=pattern

# System evolution (disabled in test by default)
# ENABLE_SYSTEM_EVOLUTION=false
# SYSTEM_CORE_OWNER_EMAIL=

# Sandbox concurrency
# MAX_CONCURRENT_DOCKER_RUNS=3

# Server schedulers are disabled in test by default.
# SERVER_DAILY_REPORT_SCHEDULER_ENABLED=false
# SERVER_DAILY_REPORT_SCHEDULER_INTERVAL_SECONDS=60
# SERVER_AUTOMATION_SCHEDULER_ENABLED=false
# SERVER_AUTOMATION_SCHEDULER_INTERVAL_SECONDS=60
# SERVER_MEMORY_ACCESS_LOG_RETENTION_ENABLED=false
# SERVER_MEMORY_ACCESS_LOG_RETENTION_DAYS=90
# SERVER_MEMORY_ACCESS_LOG_PRUNE_INTERVAL_SECONDS=3600
# SERVER_INTAKE_EXTRACTION_SCHEDULER_ENABLED=false
# SERVER_INTAKE_EXTRACTION_SCHEDULER_INTERVAL_SECONDS=30

# Backup stays disabled by default for tests (server enforces policy).
BACKUP_ENABLED=false
# BACKUP_INTERVAL_HOURS=24
# BACKUP_RETENTION_COUNT=7
# BACKUP_INCLUDE_LOGS=false
# BACKUP_ON_STARTUP=false
# BACKUP_ROOT=
# BACKUP_DATABASE_URL=

# Rare path overrides
# WORKSPACE_ROOT=/aspace/workspaces
# SANDBOX_ROOT=/aspace/sandboxes

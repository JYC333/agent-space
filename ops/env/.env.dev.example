# Development environment template.
# scripts/start.sh --dev copies this to $ASPACE_ROOT/dev/.env on first run.
# Edit the copied file, not this template.

POSTGRES_MAJOR=18
POSTGRES_DB=agent_space
POSTGRES_USER=agent_space
POSTGRES_PASSWORD=agent_space_dev_password
# DATABASE_URL=postgresql+psycopg://agent_space:agent_space_dev_password@localhost:5432/agent_space

# Control-plane: default client-facing API entrypoint.
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8010
CONTROL_PLANE_ENABLE_PYTHON_FALLBACK_PROXY=true
CONTROL_PLANE_LOG_LEVEL=info
CONTROL_PLANE_REQUEST_TIMEOUT_MS=300000
CONTROL_PLANE_PYTHON_API_BASE_URL=http://backend:8000
# Provider, credential, run execution, and policy enforcement authority default to the
# TypeScript implementation in dev. start.sh/migrate.sh generate the local DB
# role password and internal token, then migrate.sh grants the least-privilege
# DB permissions.
CONTROL_PLANE_PROVIDERS_AUTHORITY=ts
CONTROL_PLANE_PROVIDERS_CREDENTIALS_AUTHORITY=ts
CONTROL_PLANE_RUNS_AUTHORITY=ts
CONTROL_PLANE_POLICY_AUTHORITY=ts
CONTROL_PLANE_PROPOSALS_AUTHORITY=ts
# Stage 6 sessions slice: list/get/create sessions and list/add messages served by TS.
# Session reflect stays Python-owned.
CONTROL_PLANE_SESSIONS_AUTHORITY=ts
# Stage 6 chat-turn slice: /agents/{agent_id}/chat outer orchestration served by TS.
# Context/run preparation still uses Python internal ports until the context slice moves.
CONTROL_PLANE_CHAT_TURN_AUTHORITY=ts
# Stage 6 context-assembly slice: TS owns chat context selection + snapshot persistence.
# Python keeps the candidate-read and run-create ports.
CONTROL_PLANE_CONTEXT_AUTHORITY=ts
# Stage 6 memory slices: TS owns /memory list/get/search, public memory
# proposal creation, and accepted memory_create/update/archive apply.
CONTROL_PLANE_MEMORY_AUTHORITY=ts
CONTROL_PLANE_MEMORY_APPLY_AUTHORITY=ts
CONTROL_PLANE_DB_RW_USER=agent_space_cp
# CONTROL_PLANE_DB_RW_PASSWORD=<auto-generated by ops scripts>
CONTROL_PLANE_PROVIDERS_SHADOW=false
# CONTROL_PLANE_DATABASE_URL=<auto-generated by ops scripts>
CONTROL_PLANE_INTERNAL_URL=http://control-plane:8010
# CONTROL_PLANE_INTERNAL_TOKEN=<auto-generated by ops scripts>
CONTROL_PLANE_CLI_TOOLS_ROOT=/aspace/runtime-tools

# Web dev-server API proxy target inside the compose network. Browser code uses
# same-origin /api/v1/*; Vite forwards those requests to this control-plane URL.
CONTROL_PLANE_API_URL=http://control-plane:8010

# Google OAuth local defaults
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/google/callback
# FRONTEND_URL=http://localhost:3000

# Auth and defaults
# DEBUG=false
# SESSION_EXPIRE_DAYS=30
# DEFAULT_USER_ID=default_user
# REFLECTOR_MODE=pattern

# Sandbox concurrency
# MAX_CONCURRENT_DOCKER_RUNS=3

# System evolution
# ENABLE_SYSTEM_EVOLUTION=false
# SYSTEM_CORE_OWNER_EMAIL=

# Backup
# BACKUP_ENABLED=false
# BACKUP_ACCEPT_NO_BACKUP=false
# BACKUP_INTERVAL_HOURS=24
# BACKUP_RETENTION_COUNT=7
# BACKUP_INCLUDE_LOGS=false
# BACKUP_ON_STARTUP=true
# BACKUP_ROOT=

# Rare path overrides
# WORKSPACE_ROOT=/aspace/workspaces
# SANDBOX_ROOT=/aspace/sandboxes

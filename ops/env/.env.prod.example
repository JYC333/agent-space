# Production environment template.
# scripts/start.sh --prod copies this to $ASPACE_ROOT/prod/.env on first run.
# Edit the copied file before starting production.

POSTGRES_MAJOR=18
POSTGRES_DB=agent_space
POSTGRES_USER=agent_space

# Required: replace with a strong unique password.
# start.sh --prod rejects this placeholder and the development password.
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# Optional external database override. If unset, docker-compose.prod.yml uses
# the bundled postgres service with the POSTGRES_* values above.
# DATABASE_URL=postgresql+psycopg://agent_space:<strong-password>@postgres:5432/agent_space

# Control-plane: default public API entrypoint. In production nginx serves the
# web app and proxies /api/* to this service; Python stays behind the fallback
# proxy and is not published directly.
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8010
CONTROL_PLANE_ENABLE_PYTHON_FALLBACK_PROXY=true
CONTROL_PLANE_LOG_LEVEL=info
CONTROL_PLANE_REQUEST_TIMEOUT_MS=300000
CONTROL_PLANE_PYTHON_API_BASE_URL=http://backend:8000
# Provider commands, credential channel, run execution command, and policy
# enforcement authority are TS-owned by default for new production stacks.
# start.sh/migrate.sh auto-create and grant the least-privilege agent_space_cp
# role after the schema is
# available.
CONTROL_PLANE_PROVIDERS_AUTHORITY=ts
CONTROL_PLANE_PROVIDERS_CREDENTIALS_AUTHORITY=ts
CONTROL_PLANE_RUNS_AUTHORITY=ts
CONTROL_PLANE_POLICY_AUTHORITY=ts
# Stage 6 sessions slice: public session commands are TS-owned; reflect stays
# Python-owned. Flipping prod is a deliberate per-context decision under
# TS_MIGRATION_STRATEGY §8.
CONTROL_PLANE_SESSIONS_AUTHORITY=ts
# Stage 6 chat-turn slice: /agents/{agent_id}/chat outer orchestration is
# TS-owned. Context/run preparation still uses Python internal ports until the
# context slice moves.
CONTROL_PLANE_CHAT_TURN_AUTHORITY=ts
# Stage 6 context-assembly slice: TS owns chat context selection + snapshot
# persistence; Python keeps the candidate-read and run-create ports. Flipping
# prod is a deliberate per-context decision under TS_MIGRATION_STRATEGY §8.
CONTROL_PLANE_CONTEXT_AUTHORITY=ts
# TS owns /memory list/get/search (can_read_memory visibility), public memory
# proposal creation, and accepted memory proposal apply (no env switch needed
# for apply).
CONTROL_PLANE_MEMORY_AUTHORITY=ts
CONTROL_PLANE_DB_RW_USER=agent_space_cp
# CONTROL_PLANE_DB_RW_PASSWORD=<auto-generated by ops scripts when TS authority is enabled>
CONTROL_PLANE_PROVIDERS_SHADOW=false
# CONTROL_PLANE_DATABASE_URL=<auto-generated by ops scripts when TS authority is enabled>
CONTROL_PLANE_INTERNAL_URL=http://control-plane:8010
# CONTROL_PLANE_INTERNAL_TOKEN=<auto-generated by ops scripts when TS authority is enabled>
CONTROL_PLANE_CLI_TOOLS_ROOT=/aspace/runtime-tools

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://your-domain.example/api/v1/auth/google/callback
# FRONTEND_URL=https://your-domain.example

# Auth and defaults
DEBUG=false
# SESSION_EXPIRE_DAYS=30
# DEFAULT_USER_ID=default_user
# REFLECTOR_MODE=pattern

# Sandbox concurrency
# MAX_CONCURRENT_DOCKER_RUNS=3

# Backups: production refuses control-plane startup when backups are disabled unless
# BACKUP_ACCEPT_NO_BACKUP=true acknowledges the risk. Backup scheduler runs in
# the control-plane process.
BACKUP_ENABLED=true
BACKUP_ACCEPT_NO_BACKUP=false
# BACKUP_INTERVAL_HOURS=24
# BACKUP_RETENTION_COUNT=7
# BACKUP_INCLUDE_LOGS=false
# BACKUP_ON_STARTUP=true
# BACKUP_ROOT=
# BACKUP_DATABASE_URL defaults to DATABASE_URL in compose. Override only if the
# backup dump must use a distinct full-privilege PostgreSQL role.
# BACKUP_DATABASE_URL=

# Rare path overrides
# WORKSPACE_ROOT=/aspace/workspaces
# SANDBOX_ROOT=/aspace/sandboxes

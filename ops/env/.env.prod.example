# Production environment template.
# scripts/start.sh --prod copies this to $ASPACE_ROOT/prod/.env on first run.
# Edit the copied file before starting production.

POSTGRES_MAJOR=18
POSTGRES_DB=agent_space
POSTGRES_USER=agent_space

# Required: replace with a strong unique password.
# start.sh --prod rejects this placeholder and the development password.
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_PASSWORD

# Optional external database override. If unset, docker-compose.prod.yml uses
# the bundled postgres service with the POSTGRES_* values above.
# DATABASE_URL=postgresql://agent_space:<strong-password>@postgres:5432/agent_space

# Server: internal API entrypoint. In production nginx serves the
# web app and proxies /api/* to this service.
SERVER_LOG_LEVEL=info
SERVER_REQUEST_TIMEOUT_MS=300000
# start.sh/migrate.sh generate the bundled-postgres owner DB URL and internal token.
# SERVER_DATABASE_URL=<auto-generated from POSTGRES_* by ops scripts>
# SERVER_INTERNAL_TOKEN=<auto-generated by ops scripts>
RUNTIME_TOOLS_ROOT=/aspace/runtime-tools

# Optional runtime tool npm install network config. Leave these unset when the
# server container can reach the npm registry directly. If a proxy runs on the
# host or network, use an address reachable from the container.
# HTTPS_PROXY=http://proxy.example:7890
# HTTP_PROXY=http://proxy.example:7890
# ALL_PROXY=socks5h://proxy.example:7890
# NO_PROXY=localhost,127.0.0.1,postgres,server,frontend,deployer
# NPM_CONFIG_REGISTRY=https://registry.npmjs.org/

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://your-domain.example/api/v1/auth/google/callback
# FRONTEND_URL=https://your-domain.example

# Auth and defaults
SERVER_DEBUG=false
# SESSION_EXPIRE_DAYS=30
# DEFAULT_USER_ID=default_user
# REFLECTOR_MODE=pattern

# System evolution — registers the agent-space repo as a system_core workspace on startup.
# ENABLE_SYSTEM_EVOLUTION=false
# INSTANCE_ADMIN_EMAIL=owner@example.com
# SYSTEM_CORE_OWNER_EMAIL=  # override only when the system_core workspace owner differs from INSTANCE_ADMIN_EMAIL

# Schedulers + jobs worker (server process).
# SERVER_DAILY_REPORT_SCHEDULER_ENABLED=true
# SERVER_DAILY_REPORT_SCHEDULER_INTERVAL_SECONDS=60
# SERVER_AUTOMATION_SCHEDULER_ENABLED=true
# SERVER_AUTOMATION_SCHEDULER_INTERVAL_SECONDS=60
# SERVER_MEMORY_ACCESS_LOG_RETENTION_ENABLED=true
# SERVER_MEMORY_ACCESS_LOG_RETENTION_DAYS=90
# SERVER_MEMORY_ACCESS_LOG_PRUNE_INTERVAL_SECONDS=3600
# SERVER_INTAKE_EXTRACTION_SCHEDULER_ENABLED=true
# SERVER_INTAKE_EXTRACTION_SCHEDULER_INTERVAL_SECONDS=30

# Sandbox concurrency
# MAX_CONCURRENT_DOCKER_RUNS=3

# Backups: production refuses server startup when backups are disabled unless
# BACKUP_ACCEPT_NO_BACKUP=true acknowledges the risk. Backup scheduler runs in
# the server process.
BACKUP_ENABLED=true
BACKUP_ACCEPT_NO_BACKUP=false
# BACKUP_INTERVAL_HOURS=24
# BACKUP_RETENTION_COUNT=7
# BACKUP_INCLUDE_LOGS=false
# BACKUP_ON_STARTUP=true
# BACKUP_ROOT=
# BACKUP_DATABASE_URL defaults to DATABASE_URL in compose. Override only if the
# backup dump must use a distinct full-privilege PostgreSQL role.
# BACKUP_DATABASE_URL=

# Rare path overrides
# WORKSPACE_ROOT=/aspace/workspaces
# SANDBOX_ROOT=/aspace/sandboxes

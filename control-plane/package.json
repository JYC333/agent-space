{
  "name": "@agent-space/control-plane",
  "version": "0.0.0",
  "description": "Official client-facing TypeScript control plane for agent-space. Serves TS-owned routes and forwards unowned /api/v1/* requests to the Python backend through the fallback proxy.",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build:protocol": "npm --prefix ../packages/protocol run build",
    "pretypecheck": "npm run build:protocol",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "prebuild": "npm run build:protocol",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretest": "npm run build:protocol",
    "test": "vitest run",
    "pretest:watch": "npm run build:protocol",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agent-space/protocol": "file:../packages/protocol",
    "fastify": "^5.2.0",
    "node-pty": "^1.1.0",
    "pg": "^8.21.0",
    "undici": "^6.21.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "types": ["node"],
    "typeRoots": ["../../../../server/node_modules/@types"],
    "outDir": "../../../../server/dist/official-plugins/finance_ledger/server",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": false,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@agent-space/protocol": ["../../../../packages/protocol/dist/index.d.ts"],
      "fastify": ["../../../../server/node_modules/fastify"]
    }
  },
  "include": ["src"]
}

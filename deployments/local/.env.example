# This is the .env template. Do NOT edit this file directly.
# On first run, start.sh copies it to ~/aspace/config/.env (your actual secrets file).
# Edit ~/aspace/config/.env — it is never stored in the repo.

# ── Optional — Google OAuth ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI to register: http://localhost:5173/api/v1/auth/google/callback

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5173/api/v1/auth/google/callback
# FRONTEND_URL=http://localhost:5173

# Session cookies expire after this many days (default: 30)
# SESSION_EXPIRE_DAYS=30

# ── Optional — Auth ───────────────────────────────────────────────────────────

# DEBUG=false                    # set true to auto-seed a dev API key on startup

# ── Optional — Defaults ───────────────────────────────────────────────────────

# DEFAULT_SPACE_ID=personal
# DEFAULT_USER_ID=default_user
# REFLECTOR_MODE=placeholder     # or: llm (uses LLM to generate memory proposals)

# ── Optional — Sandbox concurrency ───────────────────────────────────────────

# MAX_CONCURRENT_DOCKER_RUNS=3   # max Docker containers running at the same time

# ── Data root ─────────────────────────────────────────────────────────────────
# AGENT_SPACE_HOME controls where all runtime data is stored (db, workspaces,
# sandboxes, secrets, logs, cache, etc.).
# Default (local mode): ~/aspace
# Default (Docker):     /app/aspace  (set in docker-compose.yml)
# Override only if you want a non-default location.

# AGENT_SPACE_HOME=~/aspace

# ── Optional — System Evolution ────────────────────────────────────────────────
# Register SYSTEM_CORE_REPO_PATH as a system_core workspace in the owner's
# personal space on backend startup.
# WARNING: This workspace uses system_core policy — all code changes require
# code_patch proposals, explicit approval, and git worktree sandbox execution.

# ENABLE_SYSTEM_EVOLUTION=true   # set true to enable (default: false)
# SYSTEM_CORE_OWNER_EMAIL=       # email of the user who owns the personal space

# ── Advanced path overrides (rarely needed) ───────────────────────────────────
# These override individual sub-directories within AGENT_SPACE_HOME.
# Leave unset to use the defaults derived from AGENT_SPACE_HOME.

# WORKSPACE_ROOT=~/aspace/workspaces
# SANDBOX_ROOT=~/aspace/sandboxes
# DATABASE_URL=sqlite:////home/you/aspace/db/agent_space.sqlite

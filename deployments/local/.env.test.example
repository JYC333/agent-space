# Test environment template.
# scripts/start.sh --test copies this to $ASPACE_ROOT/test/.env on first run.
# Edit the copied file, not this template.

POSTGRES_MAJOR=18
POSTGRES_DB=agent_space_test
POSTGRES_USER=agent_space
POSTGRES_PASSWORD=agent_space_dev_password
# DATABASE_URL=postgresql+psycopg://agent_space:agent_space_dev_password@localhost:5432/agent_space_test

# Test-mode auth and defaults
DEBUG=false
# SESSION_EXPIRE_DAYS=30
# DEFAULT_SPACE_ID=personal
# DEFAULT_USER_ID=default_user
# REFLECTOR_MODE=pattern

# Sandbox concurrency
# MAX_CONCURRENT_DOCKER_RUNS=3

# Backup stays disabled by default for tests.
BACKUP_ENABLED=false
# BACKUP_INTERVAL_HOURS=24
# BACKUP_RETENTION_COUNT=7
# BACKUP_INCLUDE_LOGS=false
# BACKUP_ON_STARTUP=false
# BACKUP_ROOT=

# Rare path overrides
# WORKSPACE_ROOT=/aspace/workspaces
# SANDBOX_ROOT=/aspace/sandboxes

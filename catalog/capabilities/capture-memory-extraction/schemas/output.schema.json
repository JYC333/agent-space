{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["classification", "requires_proposal", "candidates"],
  "properties": {
    "classification": {
      "type": "string",
      "enum": [
        "exploration",
        "accepted_decision",
        "stable_preference",
        "rejected_option",
        "unresolved_question"
      ]
    },
    "requires_proposal": {
      "type": "boolean"
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["proposal_type", "summary"],
        "properties": {
          "proposal_type": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  },
  "additionalProperties": true
}

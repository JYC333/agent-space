# Private deployment instance
/instance/

# External managed projects
/workspaces/

# Temporary agent execution environments
/sandboxes/

# Local operation secrets/state
/ops/env/.env

# Environment files
.env

# PostgreSQL runtime data and dumps — never committed
# (actual data lives under AGENT_SPACE_HOME/db/postgres, not in the repo)
**/db/postgres/
**/db/dumps/
*.sql.gz
*.dump

# Keep folder placeholders
!/instance/.gitkeep
!/workspaces/.gitkeep
!/sandboxes/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/

# Frontend dependencies and build output
node_modules/
server/dist/
apps/web/dist/
packages/protocol/dist/

# Rust / Tauri
apps/web/src-tauri/target/

# Logs and caches
*.log
.cache/
.DS_Store
Thumbs.db

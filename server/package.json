{
  "name": "@agent-space/server",
  "version": "0.0.0",
  "description": "Client-facing backend for agent-space.",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build:protocol": "npm --prefix ../packages/protocol run build",
    "pretypecheck": "npm run build:protocol",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "prebuild": "npm run build:protocol",
    "build": "tsc -p tsconfig.json",
    "build:official-plugins": "node scripts/build-official-plugins.mjs",
    "postbuild": "npm run build:official-plugins",
    "start": "node dist/index.js",
    "pretest": "npm run build:protocol",
    "test": "vitest run",
    "pretest:watch": "npm run build:protocol",
    "test:watch": "vitest",
    "migrate": "npm run build && node dist/db/migrateCli.js up",
    "migrate:status": "npm run build && node dist/db/migrateCli.js status",
    "schema:generate": "node scripts/db/schema-baseline.mjs generate",
    "schema:check": "node scripts/db/schema-baseline.mjs check && drizzle-kit check --config=drizzle.config.ts"
  },
  "dependencies": {
    "@agent-space/protocol": "file:../packages/protocol",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.9.3",
    "fastify": "^5.2.0",
    "node-pty": "^1.1.0",
    "pg": "^8.21.0",
    "undici": "^6.21.0",
    "unpdf": "^1.6.2",
    "yaml": "^2.9.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
